{
  "name": "ai-customer-support",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "lint:a11y": "eslint --rule 'jsx-a11y/*: error' components/ui/**/*.tsx app/_components/**/*.tsx",
    "type": "tsc --noEmit",
    "test": "NODE_ENV=test jest --config jest.config.js && NODE_ENV=test jest --config jest.integration.config.js",
    "test:unit": "NODE_ENV=test jest --config jest.config.js",
    "test:int": "NODE_ENV=test jest --config jest.integration.config.js",
    "test:watch": "NODE_ENV=test jest --config jest.config.js --watch",
    "test:coverage": "npm run test:coverage:unit && npm run test:coverage:integration",
    "test:coverage:unit": "NODE_ENV=test jest --config jest.config.js --coverage",
    "test:coverage:integration": "NODE_ENV=test jest --config jest.integration.config.js --coverage",
    "test:a11y": "NODE_ENV=test jest --config jest.accessibility.config.mjs --coverage",
    "test:a11y:check": "NODE_ENV=test jest --config jest.accessibility.config.mjs",
    "test:a11y:watch": "NODE_ENV=test jest --config jest.accessibility.config.mjs --watch",
    "test:a11y:report": "npm run test:a11y && open coverage/accessibility/lcov-report/index.html",
    "test:all": "npm run test:unit && npm run test:int && npm run test:a11y",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "typeorm": "typeorm-ts-node-commonjs",
    "db:test": "tsx scripts/test-db-connection.ts",
    "migration:generate": "tsx ./node_modules/typeorm/cli.js migration:generate -d lib/database/data-source-cli.ts",
    "migration:run": "tsx ./node_modules/typeorm/cli.js migration:run -d lib/database/data-source-cli.ts",
    "migration:revert": "tsx ./node_modules/typeorm/cli.js migration:revert -d lib/database/data-source-cli.ts",
    "seed": "tsx scripts/seed-database.ts",
    "seed:clear": "tsx scripts/seed-database.ts --clear",
    "generate:customers": "tsx scripts/generate-customers.ts",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "tsc --noEmit"
    ]
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@huggingface/inference": "^4.13.15",
    "@langchain/core": "^1.1.36",
    "@langchain/langgraph": "^1.2.5",
    "@pinecone-database/pinecone": "^7.1.0",
    "@tanstack/react-query": "^5.95.2",
    "@trpc/client": "^11.15.0",
    "@trpc/next": "^11.15.0",
    "@trpc/react-query": "^11.15.0",
    "@trpc/server": "^11.15.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "next": "16.2.1",
    "openai": "^6.33.0",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.72.0",
    "reflect-metadata": "^0.2.2",
    "tailwind-merge": "^3.5.0",
    "typeorm": "^0.3.28",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@faker-js/faker": "^10.3.0",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^29.5.14",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-unused-imports": "^4.4.1",
    "fishery": "^2.4.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-axe": "^10.0.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^16.4.0",
    "msw": "^2.12.14",
    "pg-mem": "^3.0.14",
    "tailwindcss": "^4.2.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
