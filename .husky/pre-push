#!/bin/sh

echo "🚀 Running pre-push checks..."
echo ""

# Run unit tests with coverage (minimum 70% threshold)
echo "🧪 Running unit tests with coverage (threshold: 70%)..."
npm run test:coverage:unit
UNIT_EXIT_CODE=$?

if [ $UNIT_EXIT_CODE -ne 0 ]; then
  echo ""
  echo "❌ Unit tests failed or coverage < 70%"
  echo "   Please fix failing tests or improve coverage before pushing."
  exit 1
fi

echo ""
echo "✅ Unit tests passed with sufficient coverage"
echo ""

# Run accessibility tests (WCAG 2.1 AA compliance check)
echo "♿ Running accessibility tests (WCAG 2.1 AA)..."
npm run test:a11y:check
A11Y_EXIT_CODE=$?

if [ $A11Y_EXIT_CODE -ne 0 ]; then
  echo ""
  echo "❌ Accessibility tests failed"
  echo "   Please fix accessibility violations before pushing."
  exit 1
fi

echo ""
echo "✅ Accessibility tests passed"
echo ""

# Run integration tests with coverage (minimum 70% threshold)
echo "🔗 Running integration tests with coverage (threshold: 70%)..."
npm run test:coverage:integration
INT_EXIT_CODE=$?

if [ $INT_EXIT_CODE -ne 0 ]; then
  echo ""
  echo "❌ Integration tests failed or coverage < 70%"
  echo "   Please fix failing tests or improve coverage before pushing."
  exit 1
fi

echo ""
echo "✅ Integration tests passed with sufficient coverage"
echo ""
echo "🎉 All pre-push checks completed successfully!"
echo "   Push allowed."
